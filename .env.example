# ===================================================
# mahwous-smart v26 + 2030 — إعدادات البيئة
# انسخ هذا الملف إلى .env وأضف مفاتيحك الحقيقية
# ===================================================

# --- مفاتيح Gemini (مطلوب واحد على الأقل) ---
GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_API_KEY_2=backup_key
# GEMINI_API_KEY_3=backup_key

# --- OpenRouter (اختياري - لنماذج إضافية) ---
OPENROUTER_API_KEY=

# --- Cohere (اختياري) ---
COHERE_API_KEY=

# --- Make.com Webhooks ---
MAKE_WEBHOOK_UPDATE_PRICES=
MAKE_WEBHOOK_MISSING_PRODUCTS=

# --- Apify (اختياري - للكشط السحابي) ---
APIFY_TOKEN=
APIFY_DEFAULT_ACTOR_ID=

# --- قاعدة البيانات ---
DB_PATH=data/pricing_v18.db
